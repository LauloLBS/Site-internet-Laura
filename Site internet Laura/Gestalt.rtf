\f0\b \strokec3 \'e9couter son corps
\f1\b0 \strokec3  c'est apprendre \'e0 
\f0\b \strokec3 ressentir
\f1\b0 \strokec3  ses m\'e9moires, \'e0 les 
\f0\b \strokec3 reconna\'eetre
\f1\b0 \strokec3 , les 
\f0\b \strokec3 accepter
